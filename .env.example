# 墨记 eink_diary 环境变量模板。
# 复制为 .env 并填入真实值（.env 已被 gitignore）。
# 所有占位符均为 fake，公开仓库不得出现真实凭证。

# 图像生成（复用 image_generation_skill）
# 可直接给 key，或给 1Password 引用让 op run 解析。
OPENAI_API_KEY=replace-with-your-real-key
GEMINI_API_KEY=replace-with-your-real-key
# OPENAI_API_KEY_1PASSWORD_REF=op://your-vault/your-item/your-field
# GEMINI_API_KEY_1PASSWORD_REF=op://your-vault/your-item/your-field

# 邮件/待办数据源（复用 resend_email_skill）
RESEND_API_KEY=replace-with-your-real-key
# RESEND_API_KEY_1PASSWORD_REF=op://your-vault/your-item/your-field

# 调度时间窗（24h），默认 8 点到 22 点每两小时
DIARY_START_HOUR=8
DIARY_END_HOUR=22
DIARY_INTERVAL_HOURS=2

# 风格基调（选定后填入，例如 light_rivers / dashboard_poster / ink_wash / field_guide）
DIARY_STYLE=field_guide

# 归档根目录（本地路径，不进仓库）
DIARY_ARCHIVE_DIR=./diary
