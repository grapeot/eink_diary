# 墨记 eink_diary 环境变量模板。
# 复制为 .env 并填入真实值（.env 已被 .gitignore 排除）。
# 所有占位符均为 fake，公开仓库不得出现真实凭证或私有路径。
#
# 设计原则：配置驱动的数据源启用。
#   某个源的关键配置在这里出现 → 启用该源；不出现 → 自动跳过。
#   仓库本身不绑定任何私有路径/凭证，拿到手只要按需填这个文件即可。

# ── 时间窗 ───────────────────────────────────────────────
# collector 默认采集的时间窗长度（分钟）。
DIARY_WINDOW_MINUTES=120

# ── 数据源：邮件（复用 resend_email_skill）────────────────
# 同时配置 skill 目录 + 凭证才启用邮件源。凭证可给 key 或 1Password 引用。
DIARY_RESEND_SKILL_DIR=/path/to/resend_email_skill
RESEND_API_KEY=replace-with-your-real-key
# RESEND_API_KEY_1PASSWORD_REF=op://your-vault/your-item/your-field

# ── 数据源：微信 ─────────────────────────────────────────
# 配置已解密微信 PC 版 DB 目录（含 Multi/MSG*.db）才启用微信源。
# 不配置 → 不采集微信。
DIARY_WECHAT_MSG_DIR=/path/to/wechat/Msg

# ── 数据源：AI sessions ──────────────────────────────────
# 配置导出 markdown 所在目录（含 opencode/ claude_code/ second_mind/）才启用。
DIARY_AI_SESSIONS_REPO=/path/to/ai_sessions

# ── 图像生成（复用集成进来的 image CLI）────────────────────
# 默认走 gpt-image-2（中文渲染可靠）。上游代码不改，用环境变量设默认。
IMAGE_GENERATION_MODEL=gpt-image-2
OPENAI_API_KEY=replace-with-your-real-key
GEMINI_API_KEY=replace-with-your-real-key
# OPENAI_API_KEY_1PASSWORD_REF=op://your-vault/your-item/your-field
# GEMINI_API_KEY_1PASSWORD_REF=op://your-vault/your-item/your-field

# ── 风格基调与归档（后续阶段）─────────────────────────────
DIARY_STYLE=field_guide
DIARY_ARCHIVE_DIR=./diary
